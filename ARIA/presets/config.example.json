{
  "model": "qwen2.5:14b",
  "engine": "ollama",
  "base_url": "http://localhost:11434",
  "language": "tr",
  "data_dir": "~/.aria/data",
  "log_dir": "~/.aria/logs",
  "default_agent": "simple",
  "max_tokens": 4096,
  "temperature": 0.7,
  "telemetry": false,
  "cloud_fallback": false,
  "allow_network": true,
  "allow_web_search": true,
  "allow_web_search_user_data": false,
  "allowed_base_hosts": ["localhost", "127.0.0.1"],
  "enable_tts": true,
  "tts_engine": "macos_say",
  "tts_voice": null,
  "warmup_on_start": true,
  "warmup_message": "Merhaba",
  "enable_summarization": true,
  "summary_trigger_chars": 1200,
  "summary_max_chars": 800,
  "require_auth": false,
  "api_key": null,
  "log_level": "INFO",
  "log_to_file": true,
  "allow_file_access": true,
  "allowed_file_paths": ["~/.aria"]
}
